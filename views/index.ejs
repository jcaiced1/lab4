<%- include("partials/header", { title, planetNames }) %>

<main class="hero" style="background-image: linear-gradient(rgba(4, 10, 24, 0.72), rgba(4, 10, 24, 0.88)), url('<%= backgroundImage %>');">
  <section class="container py-5">
    <div class="hero-copy">
      <p class="eyebrow">Lab 4 Express App</p>
      <h1>Explore the Solar System</h1>
      <p class="lead">
        Browse all eight planets, review core facts like moons and radius,
        and check today's Astronomy Picture of the Day from NASA.
      </p>
      <div class="hero-actions">
        <a class="btn btn-warning btn-lg" href="/nasa">See Today's NASA Image</a>
      </div>
      <% if (homeApod) { %>
        <article class="pod-preview">
          <p class="eyebrow">NASA POD Briefing</p>
          <h2><%= homeApod.title %></h2>
          <p class="pod-date"><%= homeApod.date %></p>
          <p><%= homeApod.explanation.slice(0, 210) %>...</p>
          <a href="/nasa" class="pod-link">Read the full NASA POD</a>
        </article>
      <% } %>
    </div>
  </section>
</main>

<section class="planet-showcase py-5">
  <div class="container">
    <div class="planet-showcase-copy">
      <p class="eyebrow">Planet Deck</p>
      <h2>Moving cards on the left, one focused planet on the right.</h2>
      <p class="lead mb-0">
        Hover any card to lift it out of the row and update the preview panel.
      </p>
    </div>

    <div class="planet-showcase-grid">
      <div class="planet-marquee-shell">
        <div class="planet-marquee">
          <div class="planet-marquee-track">
            <% [0, 1].forEach(() => { %>
              <div class="planet-marquee-group">
                <% planets.forEach((planet, index) => { %>
                  <article class="planet-card" data-planet-preview="<%= index %>" tabindex="0">
                    <img src="<%= planet.image %>" alt="<%= planet.name %>" class="planet-card-image">
                    <div class="planet-card-body">
                      <p class="planet-order">Solar System Planet</p>
                      <h2><%= planet.name %></h2>
                      <p>Open the planet page to see its image, number of moons, radius, year length, and more.</p>
                      <a href="/planet?planetName=<%= planet.name %>" class="btn btn-outline-light">View Details</a>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <aside class="planet-preview-panel">
        <% planets.forEach((planet, index) => { %>
          <article class="planet-preview-card<%= index === 0 ? " is-active" : "" %>" data-planet-panel="<%= index %>">
            <img src="<%= planet.image %>" alt="<%= planet.name %>" class="planet-preview-image">
            <div class="planet-preview-body">
              <p class="eyebrow">Featured Planet</p>
              <h3><%= planet.name %></h3>
              <p>
                Explore <%= planet.name %> in the detail route to review its image, moons, radius,
                year length, and the rest of the lab facts.
              </p>
              <a href="/planet?planetName=<%= planet.name %>" class="btn btn-warning">Open <%= planet.name %></a>
            </div>
          </article>
        <% }) %>
      </aside>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
<script type="module" src="/js/planet-showcase.js"></script>
