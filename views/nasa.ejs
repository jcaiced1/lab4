<%- include("partials/header", { title, planetNames }) %>

<main class="container py-5">
  <section class="nasa-panel">
    <p class="eyebrow">NASA Astronomy Picture of the Day</p>
    <h1>Today's POD</h1>

    <% if (error) { %>
      <div class="alert alert-warning mt-4"><%= error %></div>
    <% } else { %>
      <h2 class="mt-4"><%= apod.title %></h2>
      <p class="text-secondary"><strong>Date:</strong> <%= apod.date %></p>

      <% if (apod.media_type === "image") { %>
        <img src="<%= apod.url %>" alt="<%= apod.title %>" class="apod-media">
      <% } else { %>
        <div class="ratio ratio-16x9 mb-4">
          <iframe src="<%= apod.url %>" title="<%= apod.title %>" allowfullscreen></iframe>
        </div>
      <% } %>

      <p class="apod-copy"><%= apod.explanation %></p>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
