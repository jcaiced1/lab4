<%- include("partials/header", { title, planetNames }) %>

<main class="container py-5">
  <section class="planet-layout">
    <div>
      <p class="eyebrow">Solar System Explorer</p>
      <h1 class="display-4"><%= planetName %></h1>
      <p class="planet-description"><%= planetInfo.description %></p>
      <img src="<%= planetInfo.image %>" alt="<%= planetName %>" class="planet-hero-image">
    </div>

    <aside class="info-panel">
      <h2>Planet Facts</h2>
      <dl class="planet-facts">
        <div>
          <dt>Moons</dt>
          <dd><%= planetInfo.moons %></dd>
        </div>
        <div>
          <dt>Radius</dt>
          <dd><%= planetInfo.radius.toLocaleString() %> miles</dd>
        </div>
        <div>
          <dt>Length of Day</dt>
          <dd><%= planetInfo.oneEarthDay %></dd>
        </div>
        <div>
          <dt>Length of Year</dt>
          <dd><%= planetInfo.yearLength %></dd>
        </div>
        <div>
          <dt>Distance from Sun</dt>
          <dd><%= planetInfo.distanceFromSun %></dd>
        </div>
        <div>
          <dt>NASA Link</dt>
          <dd><a href="<%= planetInfo.websiteLink %>" target="_blank" rel="noreferrer">Official Overview</a></dd>
        </div>
      </dl>
    </aside>
  </section>
</main>

<%- include("partials/footer") %>
